{
  "name": "vscode-sbpf-asm",
  "displayName": "sbpf-asm",
  "description": "sBPF Assembly support for VSCode",
  "version": "0.0.4",
  "icon": "icons/logo.png",
  "publisher": "deanmlittle",
  "repository": {
    "url": "https://github.com/deanmlittle/vscode-sbpf-asm.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onDebugResolve:sbpf"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sbpf-asm",
        "aliases": [
          "sBPF Assembly",
          "sbpf-asm"
        ],
        "extensions": [
          ".sbpf",
          ".s"
        ],
        "filenamePatterns": [
          "*.s",
          "*.sbpf"
        ],
        "icon": {
          "light": "./icons/sbpf-asm.png",
          "dark": "./icons/sbpf-asm.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sbpf-asm",
        "scopeName": "source.sbpf-asm",
        "path": "./syntaxes/sbpf-asm.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "sBPF Assembly",
      "properties": {
        "sbpf-asm.showEolInfo": {
          "type": "boolean",
          "default": true,
          "description": "Show end-of-line instruction summary and meta for the current cursor line."
        },
        "sbpf-asm.sbpfPath": {
          "type": "string",
          "default": "sbpf",
          "description": "Path to the sbpf CLI."
        }
      }
    },
    "breakpoints": [
      {
        "language": "sbpf-asm"
      }
    ],
    "debuggers": [
      {
        "type": "sbpf",
        "languages": [
          "sbpf-asm"
        ],
        "label": "sBPF Debug",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to an assembly file (.s) or ELF file (.so).",
                "default": "${workspaceFolder}/src/${workspaceFolderBasename}/${workspaceFolderBasename}.s"
              },
              "input": {
                "type": "object",
                "description": "Input accounts and instruction for the program.",
                "default": {}
              },
              "computeUnitLimit": {
                "type": "number",
                "description": "Compute unit limit.",
                "default": 1400000
              },
              "maxCallDepth": {
                "type": "number",
                "description": "Maximum call depth.",
                "default": 64
              },
              "heapSize": {
                "type": "number",
                "description": "Heap size in bytes.",
                "default": 32768
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch.",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "sbpf",
            "request": "launch",
            "name": "Debug Assembly",
            "program": "${workspaceFolder}/src/${workspaceFolderBasename}/${workspaceFolderBasename}.s",
            "input": {},
            "stopOnEntry": true
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugadapter-testsupport": "^1.68.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.9.1",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
